#include <iostream>
#include <vector>
using namespace std;

struct Point {
    int x, y;
};

int orientation(Point p, Point q, Point r) {
    int val = (q.y - p.y) * (r.x - q.x) -
              (q.x - p.x) * (r.y - q.y);
    if (val == 0) return 0;      // collinear
    return (val > 0) ? 1 : 2;    // 1=clockwise, 2=counterclockwise
}

void convexHull(vector<Point>& points) {
    int n = points.size();
    if (n < 3) return;

    vector<Point> hull;

    // Find leftmost point
    int l = 0;
    for (int i = 1; i < n; i++)
        if (points[i].x < points[l].x)
            l = i;

    int p = l, q;
    do {
        hull.push_back(points[p]);

        q = (p + 1) % n;

        for (int i = 0; i < n; i++) {
            if (orientation(points[p], points[i], points[q]) == 2)
                q = i;
        }

        p = q;

    } while (p != l);

    // Print hull
    for (auto pt : hull)
        cout << "(" << pt.x << ", " << pt.y << ")\n";
}

int main() {
    vector<Point> points = {
        {0,3}, {2,2}, {1,1}, {2,1},
        {3,0}, {0,0}, {3,3}
    };

    convexHull(points);
}
